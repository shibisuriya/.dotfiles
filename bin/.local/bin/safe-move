#!/usr/bin/env zsh

# safe-move SOURCE... -t TARGET

set -e
set -f

files=()
dest=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -t)
            [[ -z "$2" || "$2" == -* ]] && {
                echo "Option -t requires an argument"
                exit 1
            }
            dest="$2"
            shift 2
            ;;
        *)
            files+=("$1")
            shift
            ;;
    esac
done

[[ ${#files[@]} -eq 0 ]] && { echo "Missing source"; exit 1; }
[[ -z "$dest" ]] && { echo "Option -t is mandatory"; exit 1; }
[[ ! -d "$dest" ]] && { echo "Target is not a directory: $dest"; exit 1; }


for f in "${files[@]}"; do
    name=$(basename "$f")

    if [[ -e "$dest/$name" ]]; then
        echo "File already exists in target: $name"
        exit 1
    fi
done

for f in "${files[@]}"; do
    rsync -a --partial -- "$f" "$dest/" || exit 1
done

for f in "${files[@]}"; do
    rsync -a --checksum --dry-run -- "$f" "$dest/" || exit 1
done

echo -e "Moved files:"

for f in "${files[@]}"; do
    rm -rf -- "$f"
    echo "$f"
done
