#!/usr/bin/env zsh

# safe-copy SOURCE... -t DIRECTORY

set -e
set -f

files=()
dest=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -t)
            [[ -z "$2" ]] && { echo "❌ -t requires a target"; exit 1; }
            dest="$2"
            shift 2
            ;;
        *)
            files+=("$1")
            shift
            ;;
    esac
done

# enforce contract
[[ -z "$dest" ]] && { echo "❌ Missing -t TARGET"; exit 1; }
[[ ${#files[@]} -eq 0 ]] && { echo "❌ No source files"; exit 1; }

# ensure destination exists
[[ ! -d "$dest" ]] && { echo "❌ Target is not a directory: $dest"; exit 1; }

# Pre-check ALL files first
for f in "${files[@]}"; do
    name=$(basename "$f")

    if [[ -e "$dest/$name" ]]; then
        echo "❌ File already exists in target: $name"
        exit 1
    fi
done

echo -e "Copying items:\n"

for f in "${files[@]}"; do
    rsync -a --partial -- "$f" "$dest/" || exit 1
    echo "$f"
done
